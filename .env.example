# ===========================================
# Vercel Environment Variables
# ===========================================
# Copy this file to .env.local or set these
# variables in your Vercel Dashboard.
#
# IMPORTANT: Variables prefixed with VITE_
# are exposed to the client-side code.
# ===========================================

# API Base URL - Required
# Set to your backend API endpoint
# Example for Vercel deployment of backend:
# https://your-backend.vercel.app/api
VITE_API_URL=https://your-api-domain.com/api

# ===========================================
# Optional: For Development Only
# ===========================================
# Local development backend URL
# VITE_API_URL=http://localhost:3000/api
