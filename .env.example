# ===========================================
# Frontend Environment Variables
# ===========================================
# Copy this file to .env.local or set these
# in your Vercel Dashboard.
#
# IMPORTANT: Variables prefixed with VITE_
# are exposed to the client-side code.
# ===========================================

# ===========================================
# API Configuration - Required
# ===========================================
# Backend API URL (include /api prefix)
# 
# Local Development:
VITE_API_URL=http://localhost:3000/api
#
# Production (Vercel):
# VITE_API_URL=https://your-backend-url.vercel.app/api

# ===========================================
# Demo Account Configuration - Optional
# ===========================================
# These are fallback defaults. Set these in
# Vercel Dashboard for production demo accounts.
VITE_DEMO_EMAIL=demo@timegrid.app
VITE_DEMO_PASSWORD=demo123
VITE_DEMO_HR_EMAIL=hr@timegrid.app
VITE_DEMO_HR_PASSWORD=hr123
